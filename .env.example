# ─────────────────────────────────────────────────────────
#  Configuración del stack del bot de la óptica
#  Copia este archivo a .env y rellena los valores.
#  (El script setup.sh lo hace por ti y genera los secretos.)
# ─────────────────────────────────────────────────────────

# Dominio que apunta a la IP pública de tu EC2 (registro A en tu DNS).
# Ejemplo: bot.tuoptica.com  — NO uses la IP cruda, Meta exige dominio con TLS.
DOMAIN=bot.tuoptica.com

# ── Postgres ──
POSTGRES_USER=n8n
POSTGRES_DB=n8n
# Genera algo largo y aleatorio:  openssl rand -hex 24
POSTGRES_PASSWORD=CAMBIA_ESTO

# ── n8n ──
# Clave de cifrado de credenciales. Genérala UNA vez y NO la cambies después,
# o n8n no podrá descifrar las credenciales guardadas.  openssl rand -hex 24
N8N_ENCRYPTION_KEY=CAMBIA_ESTO
